{
    "id": "package-manager",
    "version": "0.1.0",
    "name": "Package Manager",
    "description": "Interacting with package managers.",
    "keywords": [
        "package",
        "manager",
        "apt",
        "apt-get"
    ],
    "privileged": false,
    "init": false,
    "options": {
        "manager": {
            "type": "string",
            "enum": [
                "apt",
                "apt-get"
            ],
            "default": "apt",
            "description": "Package Manager"
        },
        "packages":{
            "type": "string",
            "default": "",
            "description": "Space-seperated string of packages to install. Version constraints can be added in a manner that the package manager understands natively."
        },
        "deleteCache":{
            "type": "boolean",
            "default": false,
            "description": "If applicable: Delete cached files."
        },
        "upgradePackages":{
            "type": "boolean",
            "default": false,
            "description": "If applicable: Upgrade installed packages."
        }
    }
}