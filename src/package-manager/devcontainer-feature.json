{
    "id": "package-manager",
    "version": "2.0.0",
    "name": "Package Manager",
    "description": "Interacting with system package managers.",
    "keywords": [
        "package",
        "manager"
    ],
    "privileged": false,
    "init": false,
    "options": {
        "packages":{
            "type": "string",
            "default": "",
            "description": "Space-seperated string of packages to install. Version constraints can be added in a manner that the package manager understands natively."
        },
        "deleteCache":{
            "type": "boolean",
            "default": false,
            "description": "If applicable: Delete cached files."
        },
        "upgradePackages":{
            "type": "boolean",
            "default": false,
            "description": "If applicable: Upgrade installed packages."
        }
    }
}